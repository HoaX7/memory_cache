{
  "name": "@hoax7/memory_cache",
  "version": "1.0.24",
  "description": "",
  "main": "lib/cjs/index.js",
  "module": "lib/esm/index.js",
  "types": "lib/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/types/index.d.ts",
      "require": "./lib/cjs/index.js",
      "import": "./lib/esm/index.js",
      "default": "./lib/cjs/index.js"
    }
  },
  "scripts": {
    "test": "ts-node -r dotenv/config test.ts",
    "dev": "ts-node -r dotenv/config index.ts",
    "clean": "rm -rf lib",
    "build:cjs": "tsc -p tsconfig.build.cjs.json",
    "build:esm": "tsc -p tsconfig.build.esm.json",
    "build": "npm run clean && npm run build:cjs && npm run build:esm && node scripts/write-esm-package-json.cjs",
    "start": "node .",
    "prepublish": "npm version patch"
  },
  "files": [
    "lib/**/*"
  ],
  "keywords": [],
  "author": "HoaX7",
  "license": "ISC",
  "devDependencies": {
    "dotenv": "^10.0.0",
    "ts-node": "^10.4.0",
    "typescript": "^4.5.2"
  },
  "dependencies": {
    "redis": "^4.0.0"
  }
}
